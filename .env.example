# ==============================================================================
# ARCHIVO MAESTRO DE VARIABLES DE ENTORNO (TENSAAS)
# ==============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo a un entorno de ejecución.
# 2. Rellena las variables con valores SEGUROS.
# 3. NUNCA subas este archivo a un repositorio público.
# ==============================================================================

# --- SEGURIDAD DE LA API ---
# Token para la comunicación entre el Dashboard y la API interna.
# Generar con: openssl rand -hex 32
API_TOKEN=REPLACE_WITH_STRONG_TOKEN

# --- BASE DE DATOS DE INFRAESTRUCTURA ---
# Credenciales para la base de datos que gestiona usuarios y empresas.
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# --- PROXY (NGINX PROXY MANAGER) ---
# Credenciales para la base de datos de NPM.
NPM_DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
NPM_DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# --- MONITORIZACIÓN ---
# Contraseña para el usuario admin de Grafana.
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# --- ALERTMANAGER (TELEGRAM) ---
# Token del bot de Telegram y Chat ID para las alertas.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- RED Y ACCESO EXTERNO ---
# Token del túnel de Cloudflare para exponer los servicios a internet.
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_WITH_YOUR_CLOUDFLARE_TOKEN

# --- RUTAS ---
# Ruta absoluta al proyecto en la máquina HOST (necesario para volúmenes Docker).
HOST_PROJECT_ROOT=/home/oscar/SaaS-multiempresa-ASIR
