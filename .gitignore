# --- SEGURIDAD Y CONFIGURACIÓN ---
# Archivo maestro de variables de entorno
.env
infra/.env
scripts/config.env
.kilo
CREDENCIALES_INFRA.md

# Credenciales generadas por los scripts
scripts/databases/credentials/*
!scripts/databases/credentials/.gitkeep

# Archivos de Authelia sensibles
infra/authelia/config/db.sqlite3
infra/authelia/config/notification.txt
infra/authelia/config/users.yml

# Logs de ejecución
scripts/logs/*.log
infra/admin-dashboard/logs/*.log
*.log

# --- INFRAESTRUCTURA Y DATOS ---
# Datos de contenedores (Base de Datos, Volúmenes)
infra/proxy/mysql/
infra/proxy/data/
infra/proxy/letsencrypt/
infra/users-db/data/
infra/users-db/users-db-v2/
infra/users-db/users-db-data/
backups/
infra/backups/
data/

# --- OTROS ---
# Python y Sistema
__pycache__/
.DS_Store
*.swp
*.bak
node_modules/
dist/
build/
.gemini/
