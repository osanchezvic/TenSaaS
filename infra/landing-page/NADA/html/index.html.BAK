<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TenSaaS | Infraestructura en la Nube</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <header class="hero">
        <video autoplay muted loop playsinline class="hero-video">
            <source src="assets/videos/background.mp4" type="video/mp4">
        </video>
        <div class="overlay">
            <h1>Infraestructura SaaS Escalable</h1>
            <p>Potencia tu negocio con servicios de vanguardia en la nube.</p>
            <a href="#contacto" class="btn">Solicitar Información</a>
        </div>
    </header>

    <section id="servicios">
        <h2>Nuestros Servicios</h2>
        <div class="grid">
            <div class="card"><h3>Cloud Hosting</h3><p>Alta disponibilidad y rendimiento.</p></div>
            <div class="card"><h3>Seguridad</h3><p>Protección perimetral avanzada.</p></div>
            <div class="card"><h3>Soporte 24/7</h3><p>Atención especializada siempre.</p></div>
        </div>
    </section>

    <section id="contacto">
        <h2>Contacto</h2>
        <form action="https://formspree.io/f/TU_ID_AQUI" method="POST">
            <input type="text" name="nombre" placeholder="Tu nombre" required>
            <input type="email" name="email" placeholder="Tu correo" required>
            <textarea name="mensaje" placeholder="Describe tu necesidad"></textarea>
            <button type="submit" class="btn">Enviar Solicitud</button>
        </form>
    </section>
</body>
</html>
