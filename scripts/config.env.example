# Directorios
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROYECTO_ROOT="$(dirname "$SCRIPT_PATH")"
CATALOGO_DIR="$PROYECTO_ROOT/catalogo"
DB_DIR="$SCRIPT_PATH/databases"
CREDENTIALS_DIR="$DB_DIR/credentials"
LOG_DIR="$PROYECTO_ROOT/scripts/logs"
DATA_DIR="$PROYECTO_ROOT/data"
DOCKER_DATA_DIR="${HOST_PROJECT_ROOT:-$PROYECTO_ROOT}/data"

# Puertos: rango para asignar (8100-8999)
PUERTO_MIN=8100
PUERTO_MAX=8999

# Modo forzado (sin confirmaciones)
FORCE_MODE=0

# NPM API
NPM_URL="http://127.0.0.1:81"
NPM_USER="osanchezvic@gmail.com"
NPM_PASSWORD="k0ntraS3na.M3d4"
NPM_CERT_ID=5 # Identificador de tu certificado wildcard en NPM

# Colores para terminal
